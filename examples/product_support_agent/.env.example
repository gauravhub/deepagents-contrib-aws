# S3 bucket for persistent storage (required)
S3_BACKEND_BUCKET=my-bucket

# Key prefix for all S3 objects (optional)
S3_BACKEND_PREFIX=product-support/

# AWS region for AgentCore Code Interpreter (required)
AGENTCORE_REGION=us-west-2

# AWS region for S3 (optional — falls back to ~/.aws/config)
# AWS_REGION=us-west-2
# AWS_DEFAULT_REGION=us-west-2

# AWS credentials (if not using IAM role, SSO, or ~/.aws/credentials)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...
